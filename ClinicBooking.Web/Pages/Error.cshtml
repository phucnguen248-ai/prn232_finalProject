@page
@model ErrorModel
@{
    ViewData["Title"] = "Đã xảy ra lỗi";
}

<div class="state-page">
    <div class="state-icon state-icon-danger" aria-hidden="true">
        <i class="bi bi-exclamation-triangle"></i>
    </div>
    <span class="eyebrow-text">Không thể hoàn tất yêu cầu</span>
    <h1 class="h2 mb-2">Đã xảy ra lỗi</h1>
    <p class="text-muted mb-4">Hệ thống đang gặp sự cố tạm thời. Vui lòng quay lại trang chủ hoặc thử lại sau ít phút.</p>
    <div class="d-flex flex-column flex-sm-row justify-content-center gap-2">
        <a href="/" class="btn btn-primary-gradient px-4">
            <i class="bi bi-house me-1" aria-hidden="true"></i>Về trang chủ
        </a>
        <button type="button" class="btn btn-outline-secondary px-4" onclick="window.location.reload()">
            <i class="bi bi-arrow-clockwise me-1" aria-hidden="true"></i>Thử lại
        </button>
    </div>
    @if (Model.ShowRequestId)
    {
        <p class="state-reference mb-0">
            Mã tham chiếu: <code>@Model.RequestId</code>
        </p>
    }
</div>
