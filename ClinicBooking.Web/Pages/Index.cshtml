@page
@model IndexModel
@{
    ViewData["Title"] = "Trang chủ & Tra cứu Bác sĩ";
}

<section class="hero-section home-hero mb-4">
    <div class="row align-items-center g-4">
        <div class="col-lg-7">
            <div class="hero-eyebrow">
                <i class="bi bi-shield-check" aria-hidden="true"></i>
                Đặt lịch an tâm, khám đúng giờ
            </div>
            <h1 class="mb-3">Chăm sóc sức khỏe bắt đầu từ một lịch hẹn thuận tiện.</h1>
            <p class="lead mb-4">Tìm đúng bác sĩ, chọn giờ khám phù hợp và theo dõi lịch hẹn của bạn trên một nền tảng duy nhất.</p>
            <div class="d-flex flex-column flex-sm-row gap-2">
                <a href="/Booking/Index" class="btn btn-gold btn-lg px-4">
                    <i class="bi bi-calendar2-plus me-2" aria-hidden="true"></i>Đặt lịch khám
                </a>
                <a href="#doctor-search" class="btn btn-hero-secondary btn-lg px-4">
                    <i class="bi bi-search me-2" aria-hidden="true"></i>Tìm bác sĩ
                </a>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="hero-assurance">
                <div class="assurance-item">
                    <span><i class="bi bi-person-check" aria-hidden="true"></i></span>
                    <div>
                        <strong>Bác sĩ theo chuyên khoa</strong>
                        <small>Thông tin chuyên môn rõ ràng</small>
                    </div>
                </div>
                <div class="assurance-item">
                    <span><i class="bi bi-clock-history" aria-hidden="true"></i></span>
                    <div>
                        <strong>Khung giờ cập nhật tức thời</strong>
                        <small>Chủ động chọn lịch phù hợp</small>
                    </div>
                </div>
                <div class="assurance-item">
                    <span><i class="bi bi-bell" aria-hidden="true"></i></span>
                    <div>
                        <strong>Quản lý lịch hẹn dễ dàng</strong>
                        <small>Theo dõi mọi trạng thái khám</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="trust-strip mb-4" aria-label="Lợi ích của ClinicBooking">
    <div><i class="bi bi-lightning-charge-fill" aria-hidden="true"></i><span><strong>Đặt nhanh</strong> trong vài phút</span></div>
    <div><i class="bi bi-calendar2-check-fill" aria-hidden="true"></i><span><strong>Lịch rõ ràng</strong> theo từng bác sĩ</span></div>
    <div><i class="bi bi-lock-fill" aria-hidden="true"></i><span><strong>Thông tin</strong> được bảo mật</span></div>
</div>

<section class="card card-premium search-panel p-4 mb-4" id="doctor-search">
    <div class="section-heading mb-3">
        <span class="section-icon"><i class="bi bi-search-heart" aria-hidden="true"></i></span>
        <div>
            <h2 class="h4 mb-1">Tìm bác sĩ phù hợp</h2>
            <p class="text-muted mb-0">Tra cứu theo tên hoặc chuyên khoa bạn đang quan tâm.</p>
        </div>
    </div>
    <div class="row g-3">
        <div class="col-md-5">
            <label class="form-label fw-semibold" for="searchName">Tên bác sĩ</label>
            <div class="input-icon-wrap">
                <i class="bi bi-person" aria-hidden="true"></i>
                <input type="search" id="searchName" class="form-control" placeholder="Ví dụ: Nguyễn Văn An" />
            </div>
        </div>
        <div class="col-md-5">
            <label class="form-label fw-semibold" for="searchSpec">Chuyên khoa</label>
            <select id="searchSpec" class="form-select" disabled>
                <option value="">Đang tải chuyên khoa...</option>
            </select>
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <button id="btnSearch" class="btn btn-primary-gradient w-100">
                <i class="bi bi-funnel me-1"></i> Lọc dữ liệu
            </button>
        </div>
    </div>
</section>

<div class="results-heading">
    <div>
        <span class="eyebrow-text">Đội ngũ chuyên môn</span>
        <h2 class="h4 mb-0">Bác sĩ đang nhận lịch</h2>
    </div>
    <span class="results-note"><i class="bi bi-arrow-repeat me-1" aria-hidden="true"></i>Lịch trống được cập nhật liên tục</span>
</div>

<div class="row g-4" id="doctorListContainer">
    <div class="col-12 text-center py-5 text-muted">
        <div class="spinner-border text-brand" role="status"></div>
        <p class="mt-2">Đang tải danh sách Bác sĩ từ hệ thống...</p>
    </div>
</div>

@section Scripts {
    <script>
        function loadSpecializations() {
            const $select = $('#searchSpec');

            $.ajax({
                url: `${API_BASE_URL}/specializations?$orderby=Name`,
                type: 'GET',
                success: function(specializations) {
                    $select.empty().append(
                        $('<option>', { value: '', text: 'Tất cả chuyên khoa' })
                    );

                    (specializations || []).forEach(function(specialization) {
                        $select.append($('<option>', {
                            value: specialization.name,
                            text: specialization.name
                        }));
                    });

                    $select.prop('disabled', false);
                },
                error: function() {
                    $select.empty().append(
                        $('<option>', { value: '', text: 'Không thể tải chuyên khoa' })
                    );
                }
            });
        }

        function loadDoctors() {
            const name = $('#searchName').val().trim();
            const spec = ($('#searchSpec').val() || '').trim();

            $('#doctorListContainer').html(`
                <div class="col-12 text-center py-5 text-muted">
                    <div class="spinner-border text-brand" role="status"></div>
                    <p class="mt-2">Đang tìm kiếm Bác sĩ...</p>
                </div>
            `);

            $.ajax({
                url: `${API_BASE_URL}/doctors/search?name=${encodeURIComponent(name)}&specialization=${encodeURIComponent(spec)}`,
                type: 'GET',
                success: function(data) {
                    renderDoctorCards(data);
                },
                error: function() {
                    $('#doctorListContainer').html(`
                        <div class="col-12 text-center py-5 text-danger">
                            <i class="bi bi-exclamation-triangle fs-1 d-block mb-3"></i>
                            <h5>Không thể tải danh sách bác sĩ.</h5>
                            <p class="mb-0">Vui lòng kiểm tra API và thử lại.</p>
                        </div>
                    `);
                }
            });
        }

        function renderDoctorCards(doctors) {
            if (!doctors || doctors.length === 0) {
                $('#doctorListContainer').html(`
                    <div class="col-12 text-center py-5 text-muted">
                        <i class="bi bi-person-x fs-1 d-block mb-3 text-secondary"></i>
                        <h5>Không tìm thấy bác sĩ phù hợp với từ khóa lọc.</h5>
                    </div>
                `);
                return;
            }

            let html = '';
            doctors.forEach(doc => {
                const fullName = escapeHtml(doc.fullName);
                const specializationName = escapeHtml(doc.specializationName || 'Chuyên khoa');
                const licenseNumber = escapeHtml(doc.licenseNumber || 'N/A');
                const bio = escapeHtml(doc.bio || 'Bác sĩ giàu kinh nghiệm, tận tâm với bệnh nhân.');

                html += `
                    <div class="col-12 col-md-6 col-xl-4">
                        <div class="card card-premium doctor-card h-100">
                            <div class="card-body d-flex flex-column">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="doctor-avatar me-3">
                                        <i class="bi bi-person-badge fs-4"></i>
                                    </div>
                                    <div>
                                        <h5 class="card-title mb-0 fw-bold">${fullName}</h5>
                                        <span class="badge bg-primary-subtle text-primary-emphasis mt-1">${specializationName}</span>
                                    </div>
                                </div>
                                <p class="card-text text-muted small mb-2"><i class="bi bi-patch-check me-1 text-warning"></i> CCHN: ${licenseNumber}</p>
                                <p class="card-text text-muted small mb-3"><i class="bi bi-award me-1 text-success"></i> Kinh nghiệm: ${doc.yearsOfExperience || 0} năm</p>
                                <p class="card-text doctor-bio text-secondary mb-4 flex-grow-1">${bio}</p>
                                <a href="/Booking/Index?doctorId=${doc.doctorId}" class="btn btn-primary-gradient w-100 mt-auto">
                                    <i class="bi bi-calendar2-check me-1"></i> Xem lịch & Đặt hẹn
                                </a>
                            </div>
                        </div>
                    </div>
                `;
            });
            $('#doctorListContainer').html(html);
        }

        $(document).ready(function() {
            loadSpecializations();
            loadDoctors();
            $('#btnSearch').click(loadDoctors);
            $('#searchName').on('keypress', function(e) {
                if (e.which === 13) loadDoctors();
            });
            $('#searchSpec').on('change', loadDoctors);
        });
    </script>
}
