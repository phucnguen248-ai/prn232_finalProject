@page
@model ClinicBooking.Web.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "Đăng Nhập";
}

<div class="row justify-content-center py-5">
    <div class="col-md-5">
        <div class="card card-premium p-4">
            <div class="text-center mb-4">
                <div class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-circle mb-3" style="width: 60px; height: 60px;">
                    <i class="bi bi-person-lock fs-2"></i>
                </div>
                <h3 class="fw-bold text-dark">Đăng Nhập Hệ Thống</h3>
                <p class="text-muted fs-7">Vui lòng nhập email và mật khẩu để tiếp tục</p>
            </div>

            <div id="login-alert" class="alert alert-danger d-none mb-3"></div>

            <form id="form-login">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Địa chỉ Email</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="bi bi-envelope"></i></span>
                        <input type="email" id="login-email" class="form-control" placeholder="admin@clinic.com" required />
                    </div>
                </div>
                <div class="mb-4">
                    <label class="form-label fw-semibold">Mật khẩu</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="bi bi-key"></i></span>
                        <input type="password" id="login-password" class="form-control" placeholder="••••••••" required />
                    </div>
                </div>

                <button type="submit" class="btn btn-primary-gradient w-100 py-2 mb-3 fs-6">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Đăng Nhập ngay
                </button>
            </form>

            <hr class="my-4" />

            <div class="text-center">
                <p class="text-muted small mb-2">Đăng nhập nhanh cho demo (Quick Fill):</p>
                <div class="d-flex flex-wrap justify-content-center gap-2">
                    <button class="btn btn-outline-danger btn-sm" onclick="quickFill('admin@clinic.com', 'Admin123!')">Admin</button>
                    <button class="btn btn-outline-warning text-dark btn-sm" onclick="quickFill('staff@clinic.com', 'Staff123!')">Staff</button>
                    <button class="btn btn-outline-info text-dark btn-sm" onclick="quickFill('doctor1@clinic.com', 'Doctor123!')">Doctor</button>
                    <button class="btn btn-outline-success btn-sm" onclick="quickFill('patient1@clinic.com', 'Patient123!')">Patient</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function quickFill(email, password) {
        $("#login-email").val(email);
        $("#login-password").val(password);
    }

    $("#form-login").on("submit", function(e) {
        e.preventDefault();
        const email = $("#login-email").val().trim();
        const password = $("#login-password").val();

        $("#login-alert").addClass("d-none").text("");

        $.ajax({
            url: `${API_BASE_URL}/auth/login`,
            type: "POST",
            contentType: "application/json",
            data: JSON.stringify({ email: email, password: password }),
            success: function(response) {
                setAuthSession(response.token, response.user);

                if (response.user.role === "Admin") {
                    window.location.href = "/Admin/Specializations";
                } else if (response.user.role === "Staff") {
                    window.location.href = "/Staff/Reception";
                } else if (response.user.role === "Doctor") {
                    window.location.href = "/Doctor/Workspace";
                } else {
                    window.location.href = "/";
                }
            },
            error: function(xhr) {
                let errMsg = "Đăng nhập thất bại. Vui lòng thử lại.";
                if (xhr.status === 0) {
                    errMsg = "Không thể kết nối tới Backend API (http://localhost:5036). Hãy đảm bảo project ClinicBooking.Api đang chạy!";
                } else if (xhr.responseJSON && xhr.responseJSON.message) {
                    errMsg = xhr.responseJSON.message;
                }
                $("#login-alert").removeClass("d-none").text(errMsg);
            }
        });
    });
</script>
}
