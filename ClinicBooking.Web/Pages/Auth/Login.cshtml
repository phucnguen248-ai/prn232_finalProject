@page
@model ClinicBooking.Web.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "Đăng Nhập";
}

<div class="row justify-content-center py-5">
    <div class="col-md-5">
        <div class="card card-premium p-4">
            <div class="text-center mb-4">
                <h3 class="fw-bold text-dark mb-1">Đăng Nhập Hệ Thống</h3>
                <p class="text-muted fs-7">Vui lòng nhập email và mật khẩu để tiếp tục</p>
            </div>

            <div id="login-alert" class="alert alert-danger d-none mb-3"></div>

            <form id="form-login">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Địa chỉ Email</label>
                    <input type="email" id="login-email" class="form-control" placeholder="admin@clinic.com" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Mật khẩu</label>
                    <input type="password" id="login-password" class="form-control" placeholder="••••••••" required />
                </div>

                <button type="submit" class="btn btn-primary-gradient w-100 py-2 mb-3 fs-6 font-semibold">
                    Đăng Nhập Ngay
                </button>

                <div class="text-center mb-3">
                    <a href="#" class="fs-7 text-primary text-decoration-none fw-semibold" onclick="openForgotPasswordModal(event)">
                        Quên mật khẩu?
                    </a>
                </div>

                <div class="text-center pt-3 border-top">
                    <p class="text-muted fs-7 mb-2">Bạn là bệnh nhân mới chưa có tài khoản?</p>
                    <button type="button" class="btn btn-outline-success w-100 font-semibold py-2" onclick="openRegisterModal()">
                        Đăng Ký Tài Khoản Bệnh Nhân Mới
                    </button>
                </div>
            </form>

            <hr class="my-4" />

            <div class="text-center">
                <p class="text-muted small mb-2">Đăng nhập nhanh cho demo (Quick Fill):</p>
                <div class="d-flex flex-wrap justify-content-center gap-2">
                    <button class="btn btn-outline-danger btn-sm" onclick="quickFill('admin@clinic.com', 'Admin123!')">Admin</button>
                    <button class="btn btn-outline-warning text-dark btn-sm" onclick="quickFill('staff@clinic.com', 'Staff123!')">Staff</button>
                    <button class="btn btn-outline-info text-dark btn-sm" onclick="quickFill('doctor1@clinic.com', 'Doctor123!')">Doctor</button>
                    <button class="btn btn-outline-success btn-sm" onclick="quickFill('patient1@clinic.com', 'Patient123!')">Patient</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Forgot Password -->
<div class="modal fade" id="modalForgotPassword" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white py-3">
                <h5 class="modal-title fw-bold fs-6">Đặt Lại Mật Khẩu Tự Động</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div id="forgot-alert-error" class="alert alert-danger d-none mb-3"></div>

                <form id="form-forgot-password">
                    <p class="text-muted fs-7 mb-3">Nhập Email và Số điện thoại đã đăng ký để hệ thống xác thực tài khoản của bạn.</p>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Địa Chỉ Email <span class="text-danger">*</span></label>
                        <input type="email" id="forgot-email" class="form-control" placeholder="Nhập email tài khoản" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Số Điện Thoại <span class="text-danger">*</span></label>
                        <input type="text" id="forgot-phone" class="form-control" placeholder="Nhập số điện thoại đã đăng ký" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Mật Khẩu Mới <span class="text-danger">*</span></label>
                        <input type="password" id="forgot-new-password" class="form-control" placeholder="•••••••• (Ít nhất 6 ký tự)" required />
                    </div>

                    <div class="text-end mt-4">
                        <button type="button" class="btn btn-light me-2" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-primary-gradient px-4 font-semibold">
                            Xác Nhận Đổi Mật Khẩu
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Modal Patient Registration -->
<div class="modal fade" id="modalRegisterPatient" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-success text-white py-3">
                <h5 class="modal-title fw-bold fs-6">Đăng Ký Tài Khoản Bệnh Nhân Mới</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div id="register-alert-error" class="alert alert-danger d-none mb-3"></div>

                <form id="form-register-patient">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Địa Chỉ Email <span class="text-danger">*</span></label>
                            <input type="email" id="reg-email" class="form-control" placeholder="patient@example.com" required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Mật Khẩu <span class="text-danger">*</span></label>
                            <input type="password" id="reg-password" class="form-control" placeholder="•••••••• (Từ 6 ký tự)" required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Họ và Tên <span class="text-danger">*</span></label>
                            <input type="text" id="reg-fullname" class="form-control" placeholder="Nguyễn Văn A" required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Số Điện Thoại <span class="text-danger">*</span></label>
                            <input type="text" id="reg-phone" class="form-control" placeholder="0912345678" required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Ngày Sinh</label>
                            <input type="date" id="reg-dob" class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Giới Tính</label>
                            <select id="reg-gender" class="form-select">
                                <option value="Nam">Nam</option>
                                <option value="Nữ">Nữ</option>
                                <option value="Khác">Khác</option>
                            </select>
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-semibold">Địa Chỉ Cư Trú</label>
                            <input type="text" id="reg-address" class="form-control" placeholder="Số nhà, tên đường, quận/huyện..." />
                        </div>
                    </div>

                    <div class="text-end mt-4">
                        <button type="button" class="btn btn-light me-2" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-success px-4 font-semibold">
                            Tạo Tài Khoản Bệnh Nhân
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $(document).ready(function() {
        const todayStr = new Date().toISOString().split('T')[0];
        $("#reg-dob").attr("max", todayStr).on("change", function() {
            if ($(this).val() && $(this).val() > todayStr) {
                showCustomAlert("Ngày sinh không thể ở trong tương lai. Vui lòng chọn lại!", "Cảnh Báo Ngày Sinh", "warning");
                $(this).val(todayStr);
            }
        });
    });

    function quickFill(email, password) {
        $("#login-email").val(email);
        $("#login-password").val(password);
    }

    function openForgotPasswordModal(e) {
        e.preventDefault();
        $("#forgot-email").val($("#login-email").val());
        $("#forgot-phone").val("");
        $("#forgot-new-password").val("");
        $("#forgot-alert-error").addClass("d-none").text("");
        new bootstrap.Modal('#modalForgotPassword').show();
    }

    function openRegisterModal() {
        $("#reg-email").val("");
        $("#reg-password").val("");
        $("#reg-fullname").val("");
        $("#reg-phone").val("");
        $("#reg-address").val("");
        $("#register-alert-error").addClass("d-none").text("");
        new bootstrap.Modal('#modalRegisterPatient').show();
    }

    $("#form-login").on("submit", function(e) {
        e.preventDefault();
        const email = $("#login-email").val().trim();
        const password = $("#login-password").val();

        $("#login-alert").addClass("d-none").text("");

        $.ajax({
            url: `${API_BASE_URL}/auth/login`,
            type: "POST",
            contentType: "application/json",
            data: JSON.stringify({ email: email, password: password }),
            success: function(response) {
                setAuthSession(response.token, response.user);
                const returnUrl = new URLSearchParams(window.location.search).get("returnUrl");
                const safeReturnUrl = returnUrl && returnUrl.startsWith("/") && !returnUrl.startsWith("//")
                    ? returnUrl
                    : null;

                if (response.user.role === "Admin") {
                    window.location.href = "/Admin/Dashboard";
                } else if (response.user.role === "Staff") {
                    window.location.href = "/Staff/Reception";
                } else if (response.user.role === "Doctor") {
                    window.location.href = "/Doctor/Workspace";
                } else {
                    window.location.href = safeReturnUrl || "/";
                }
            },
            error: function(xhr) {
                let errMsg = "Đăng nhập thất bại. Vui lòng thử lại.";
                if (xhr.status === 0) {
                    errMsg = "Không thể kết nối tới Backend API (http://localhost:5036). Hãy đảm bảo project ClinicBooking.Api đang chạy!";
                } else if (xhr.responseJSON && xhr.responseJSON.message) {
                    errMsg = xhr.responseJSON.message;
                }
                $("#login-alert").removeClass("d-none").text(errMsg);
            }
        });
    });

    $("#form-forgot-password").on("submit", function(e) {
        e.preventDefault();
        $("#forgot-alert-error").addClass("d-none").text("");

        const payload = {
            email: $("#forgot-email").val().trim(),
            phoneNumber: $("#forgot-phone").val().trim(),
            newPassword: $("#forgot-new-password").val()
        };

        $.ajax({
            url: `${API_BASE_URL}/auth/forgot-password`,
            type: "POST",
            contentType: "application/json",
            data: JSON.stringify(payload),
            success: function(res) {
                bootstrap.Modal.getInstance('#modalForgotPassword').hide();
                showCustomAlert(res.message, "Đổi Mật Khẩu Thành Công", "success");
                $("#login-email").val(payload.email);
                $("#login-password").val(payload.newPassword);
            },
            error: function(xhr) {
                let msg = xhr.responseJSON?.message || "Không thể đặt lại mật khẩu.";
                $("#forgot-alert-error").removeClass("d-none").text(msg);
            }
        });
    });

    $("#form-register-patient").on("submit", function(e) {
        e.preventDefault();
        $("#register-alert-error").addClass("d-none").text("");

        const payload = {
            email: $("#reg-email").val().trim(),
            password: $("#reg-password").val(),
            fullName: $("#reg-fullname").val().trim(),
            phoneNumber: $("#reg-phone").val().trim(),
            role: "Patient",
            dateOfBirth: $("#reg-dob").val() || null,
            gender: $("#reg-gender").val() || "Nam",
            address: $("#reg-address").val().trim() || null
        };

        $.ajax({
            url: `${API_BASE_URL}/auth/register`,
            type: "POST",
            contentType: "application/json",
            data: JSON.stringify(payload),
            success: function(response) {
                bootstrap.Modal.getInstance('#modalRegisterPatient').hide();
                setAuthSession(response.token, response.user);
                showCustomAlert("Đăng ký tài khoản Bệnh nhân thành công!", "Chào Mừng Bệnh Nhân Mới", "success");
                setTimeout(() => {
                    window.location.href = "/Auth/Profile";
                }, 1500);
            },
            error: function(xhr) {
                let msg = xhr.responseJSON?.message || "Không thể đăng ký tài khoản.";
                $("#register-alert-error").removeClass("d-none").text(msg);
            }
        });
    });
</script>
}
