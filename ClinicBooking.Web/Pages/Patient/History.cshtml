@page
@model ClinicBooking.Web.Pages.Patient.HistoryModel
@{
    ViewData["Title"] = "Lịch Sử Đặt Hẹn Khám Bệnh";
}

<div class="card card-premium p-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div class="d-flex align-items-center">
            <div class="patient-page-icon me-3">
                <i class="bi bi-clock-history fs-2"></i>
            </div>
            <div>
                <h3 class="text-dark fw-bold mb-1">Lịch Sử Đặt Lịch Hẹn Khám Bệnh</h3>
                <p class="text-muted mb-0">Xem danh sách các cuộc hẹn và quản lý yêu cầu hủy lịch.</p>
            </div>
        </div>
        <a href="/Booking/Index" class="btn btn-gold">
            <i class="bi bi-plus-lg me-1"></i> Đặt Lịch Mới
        </a>
    </div>

    <div class="patient-info-banner d-flex align-items-start mb-4" role="alert">
        <i class="bi bi-info-circle-fill fs-3 me-3"></i>
        <div>
            <strong>Quy tắc Hủy Lịch (Grace Period):</strong> Bạn được phép hủy lịch nếu thực hiện trong vòng <strong>15 phút</strong> sau khi đặt thành công, hoặc trước giờ khám <strong>ít nhất 2 tiếng</strong>.
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle border">
            <thead class="table-light">
                <tr>
                    <th scope="col">Mã Hẹn</th>
                    <th scope="col">Bác Sĩ</th>
                    <th scope="col">Chuyên Khoa</th>
                    <th scope="col">Thời Gian Khám</th>
                    <th scope="col">Lý Do Khám</th>
                    <th scope="col">Trạng Thái</th>
                    <th scope="col">Thao Tác Hủy Lịch</th>
                </tr>
            </thead>
            <tbody id="historyTableBody">
                <tr>
                    <td colspan="7" class="text-center py-4 text-muted">
                        <div class="spinner-border text-brand me-2" role="status"></div> Đang tải lịch sử hẹn...
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="cancelModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title fw-bold"><i class="bi bi-exclamation-triangle me-2"></i>Xác Nhận Hủy Lịch Hẹn</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-2 fs-6">Bạn có chắc chắn muốn hủy cuộc hẹn này không?</p>
                <div class="p-3 bg-light rounded border text-secondary small">
                    <i class="bi bi-exclamation-triangle me-1 text-warning"></i> Khi hủy thành công, khung giờ ca khám sẽ tự động được hoàn trả cho bệnh nhân khác đăng ký.
                </div>
                <input type="hidden" id="cancelAppointmentId" value="0" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary fw-semibold" data-bs-dismiss="modal">Đóng</button>
                <button type="button" id="btnConfirmCancel" class="btn btn-danger fw-bold">
                    <i class="bi bi-slash-circle me-1"></i> Đồng Ý Hủy Lịch
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            if (!requireRole(['Patient'])) return;

            const cancelModal = bootstrap.Modal.getOrCreateInstance(document.getElementById('cancelModal'));
            loadHistory();

            $(document).on('click', '.btn-cancel-appt', function() {
                const apptId = $(this).data('appt-id');
                $('#cancelAppointmentId').val(apptId);
                cancelModal.show();
            });

            $('#btnConfirmCancel').click(function() {
                const apptId = $('#cancelAppointmentId').val();
                if (!apptId || apptId <= 0) return;

                $('#btnConfirmCancel').prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span> Đang hủy...');

                $.ajax({
                    url: `${API_BASE_URL}/appointments/${apptId}/cancel`,
                    type: 'PATCH',
                    headers: getAuthHeaders(),
                    success: function(res) {
                        cancelModal.hide();
                        $('#btnConfirmCancel').prop('disabled', false).html('<i class="bi bi-slash-circle me-1"></i> Đồng Ý Hủy Lịch');
                        toastr.success(res.message || 'Hủy lịch hẹn thành công!');
                        loadHistory();
                    },
                    error: function(xhr) {
                        $('#btnConfirmCancel').prop('disabled', false).html('<i class="bi bi-slash-circle me-1"></i> Đồng Ý Hủy Lịch');
                        cancelModal.hide();

                        if (handleAuthError(xhr)) return;

                        if (xhr.status === 400) {
                            toastr.error(xhr.responseJSON?.message || 'Không thể hủy lịch: Đã vi phạm quy tắc Grace Period.');
                        } else {
                            toastr.error('Có lỗi xảy ra khi gửi yêu cầu hủy lịch.');
                        }
                    }
                });
            });
        });

        function loadHistory() {
            $.ajax({
                url: `${API_BASE_URL}/appointments/my-history`,
                type: 'GET',
                headers: getAuthHeaders(),
                success: function(history) {
                    renderHistoryTable(history);
                },
                error: function(xhr) {
                    if (handleAuthError(xhr)) return;

                    $('#historyTableBody').html(`
                        <tr>
                            <td colspan="7" class="text-center py-4 text-danger">
                                <i class="bi bi-exclamation-triangle me-1"></i>
                                Không thể tải lịch sử hẹn. Vui lòng thử lại.
                            </td>
                        </tr>
                    `);
                }
            });
        }

        function renderHistoryTable(list) {
            if (!list || list.length === 0) {
                $('#historyTableBody').html(`
                    <tr>
                        <td colspan="7" class="text-center py-4 text-muted">
                            <i class="bi bi-folder2-open fs-2 d-block mb-2"></i>
                            <p class="mb-0">Bạn chưa có lịch hẹn khám nào.</p>
                        </td>
                    </tr>
                `);
                return;
            }

            let html = '';
            list.forEach(item => {
                let badgeClass = 'bg-secondary';
                let statusText = item.status;

                switch(item.status) {
                    case 'Confirmed': badgeClass = 'badge-confirmed'; statusText = 'Đã Xác Nhận'; break;
                    case 'CheckedIn': badgeClass = 'badge-checkedin'; statusText = 'Đã Check-in'; break;
                    case 'Completed': badgeClass = 'badge-completed'; statusText = 'Hoàn Tất Khám'; break;
                    case 'Cancelled': badgeClass = 'badge-cancelled'; statusText = 'Đã Hủy Lịch'; break;
                    case 'NoShow': badgeClass = 'badge-noshow'; statusText = 'Bỏ Hẹn (No-Show)'; break;
                }

                const dateStr = new Date(`${item.slotDate}T00:00:00`).toLocaleDateString('vi-VN');
                const timeStr = `${item.startTime.substring(0,5)} - ${item.endTime.substring(0,5)}`;
                const doctorName = escapeHtml(item.doctorName);
                const specializationName = escapeHtml(item.specializationName);
                const reason = escapeHtml(item.reason);

                let actionBtn = '';
                if (item.status === 'Confirmed' && item.canCancel) {
                    actionBtn = `
                        <button class="btn btn-outline-danger btn-sm fw-semibold btn-cancel-appt" data-appt-id="${item.appointmentId}">
                            <i class="bi bi-x-lg me-1"></i> Hủy Lịch
                        </button>
                    `;
                } else if (item.status === 'Confirmed' && !item.canCancel) {
                    actionBtn = `<span class="text-muted small" title="Không còn trong thời hạn được phép hủy"><i class="bi bi-lock me-1"></i> Không thể hủy</span>`;
                } else {
                    actionBtn = `<span class="text-muted small">-</span>`;
                }

                html += `
                    <tr>
                        <td class="fw-bold text-brand">#${item.appointmentId}</td>
                        <td class="fw-semibold">${doctorName}</td>
                        <td><span class="badge bg-light text-dark border">${specializationName}</span></td>
                        <td>
                            <div><i class="bi bi-calendar3 me-1 text-brand"></i> ${dateStr}</div>
                            <div class="small text-muted"><i class="bi bi-clock me-1"></i> ${timeStr}</div>
                        </td>
                        <td><span class="text-truncate d-inline-block" style="max-width: 200px;" title="${reason}">${reason}</span></td>
                        <td><span class="badge ${badgeClass} badge-status">${statusText}</span></td>
                        <td>${actionBtn}</td>
                    </tr>
                `;
            });

            $('#historyTableBody').html(html);
        }
    </script>
}
