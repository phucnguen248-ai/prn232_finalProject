<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#0f766e" />
    <meta name="description" content="ClinicBooking - Nền tảng đặt lịch khám và quản lý vận hành phòng khám." />
    <title>@ViewData["Title"] | ClinicBooking</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="app-shell d-flex flex-column min-vh-100">
    <a class="skip-link" href="#main-content">Bỏ qua đến nội dung chính</a>

    <header class="app-header">
        <nav class="navbar navbar-expand-lg navbar-custom" aria-label="Điều hướng chính">
            <div class="container-xxl">
                <a class="navbar-brand navbar-brand-custom" href="/" aria-label="ClinicBooking - Trang chủ">
                    <span class="brand-mark" aria-hidden="true">
                        <i class="bi bi-heart-pulse-fill"></i>
                    </span>
                    <span class="brand-copy">
                        <span class="brand-name">Clinic<span>Booking</span></span>
                        <small>Chăm sóc chủ động</small>
                    </span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain"
                        aria-controls="navbarMain" aria-expanded="false" aria-label="Mở menu điều hướng">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 role-navigation" id="role-nav-container">
                    </ul>
                    <ul class="navbar-nav ms-auto align-items-lg-center auth-navigation" id="auth-nav-container">
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main id="main-content" role="main" class="app-main flex-grow-1">
        <div class="container-xxl">
            @RenderBody()
        </div>
    </main>

    <footer class="app-footer mt-auto">
        <div class="container-xxl">
            <div class="footer-content">
                <div class="footer-brand">
                    <span class="brand-mark brand-mark-sm" aria-hidden="true">
                        <i class="bi bi-heart-pulse-fill"></i>
                    </span>
                    <div>
                        <strong>ClinicBooking</strong>
                        <span>Nền tảng quản lý lịch khám an toàn, thuận tiện.</span>
                    </div>
                </div>
                <div class="footer-meta">
                    <span><i class="bi bi-shield-check me-1"></i>Bảo mật thông tin</span>
                    <span>&copy; 2026 ClinicBooking</span>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        toastr.options = {
            closeButton: true,
            progressBar: true,
            positionClass: "toast-top-right",
            timeOut: 4000
        };
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
