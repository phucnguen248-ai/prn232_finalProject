@page
@model PrivacyModel
@{
    ViewData["Title"] = "Chính sách bảo mật";
}

<div class="row justify-content-center">
    <div class="col-lg-9">
        <div class="card card-premium p-4 p-lg-5">
            <div class="section-heading mb-4">
                <span class="section-icon"><i class="bi bi-shield-lock" aria-hidden="true"></i></span>
                <div>
                    <span class="eyebrow-text">ClinicBooking</span>
                    <h1 class="h3 mb-1">Chính sách bảo mật</h1>
                    <p class="text-muted mb-0">Nguyên tắc bảo vệ thông tin khi sử dụng nền tảng.</p>
                </div>
            </div>
            <div class="privacy-content">
                <h2 class="h5">Thông tin được sử dụng đúng mục đích</h2>
                <p>Thông tin tài khoản và lịch khám chỉ được dùng để hỗ trợ đặt lịch, tiếp nhận bệnh nhân và vận hành phòng khám.</p>
                <h2 class="h5">Quyền truy cập được kiểm soát</h2>
                <p>Mỗi vai trò chỉ được truy cập những chức năng cần thiết cho công việc hoặc quá trình khám bệnh.</p>
                <h2 class="h5">Chủ động bảo vệ tài khoản</h2>
                <p class="mb-0">Không chia sẻ mật khẩu hoặc thông tin đăng nhập. Hãy đăng xuất khi sử dụng thiết bị dùng chung.</p>
            </div>
        </div>
    </div>
</div>
