@page
@model ClinicBooking.Web.Pages.Booking.IndexModel
@{
    ViewData["Title"] = "Đặt Lịch Khám Bệnh";
}

<div class="row justify-content-center">
    <div class="col-md-9">
        <div class="card card-premium p-4">
            <div class="d-flex align-items-center mb-4">
                <div class="patient-page-icon me-3">
                    <i class="bi bi-calendar2-check fs-2"></i>
                </div>
                <div>
                    <h3 class="fw-bold text-dark mb-1">Đăng Ký Đặt Lịch Khám Bệnh</h3>
                    <p class="text-muted mb-0">Chọn Bác sĩ, ngày khám và khung giờ phù hợp với bạn.</p>
                </div>
            </div>

            <!-- BƯỚC 1: CHỌN BÁC SĨ VÀ NGÀY -->
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Chọn Bác sĩ <span class="text-danger">*</span></label>
                    <select id="selectDoctor" class="form-select">
                        <option value="1">BS. Nguyễn Văn A (Nhi khoa)</option>
                        <option value="2">BS. Trần Thị B (Nội khoa)</option>
                        <option value="3">BS. Lê Văn C (Da liễu)</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Chọn Ngày khám <span class="text-danger">*</span></label>
                    <input type="date" id="bookingDate" class="form-control" />
                </div>
            </div>

            <!-- BƯỚC 2: CHỌN KHUNG GIỜ KHÁM (SLOTS) -->
            <div class="mb-4">
                <label class="form-label fw-semibold mb-2">
                    <i class="bi bi-clock me-1 text-brand"></i>Chọn Khung giờ khám <span class="text-danger">*</span>
                </label>
                <div id="slotsContainer" class="d-flex flex-wrap p-3 border rounded bg-light">
                    <span class="text-muted">Vui lòng chọn ngày khám để tải danh sách khung giờ rảnh.</span>
                </div>
            </div>

            <hr class="my-4" />

            <!-- BƯỚC 3: ĐIỀN THÔNG TIN BỆNH NHÂN -->
            <form id="formBooking">
                <input type="hidden" id="selectedScheduleId" value="0" />

                <h5 class="fw-bold mb-1 text-dark">
                    <i class="bi bi-person-vcard me-2 text-brand"></i>Thông Tin Bệnh Nhân & Lý Do Khám
                </h5>
                <p class="text-muted small mb-3">Thông tin cá nhân được lấy từ tài khoản đang đăng nhập.</p>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Họ và tên bệnh nhân <span class="text-danger">*</span></label>
                        <input type="text" id="patientName" class="form-control bg-light" readonly required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Số điện thoại <span class="text-danger">*</span></label>
                        <input type="tel" id="patientPhone" class="form-control bg-light" readonly required />
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">Lý do khám / Triệu chứng bệnh <span class="text-danger">*</span></label>
                    <textarea id="reason" class="form-control" rows="3" placeholder="Mô tả triệu chứng hoặc nhu cầu khám (từ 10 đến 500 ký tự)..." required></textarea>
                </div>

                <div class="d-flex flex-column flex-sm-row justify-content-between align-items-stretch align-items-sm-center gap-2">
                    <a href="/Index" class="btn btn-outline-secondary px-4 fw-semibold">
                        <i class="bi bi-arrow-left me-1"></i> Quay lại
                    </a>
                    <button type="submit" id="btnSubmitBooking" class="btn btn-primary-gradient btn-lg px-5 fw-bold" disabled>
                        <i class="bi bi-send me-2"></i> Xác Nhận Đặt Lịch
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            if (!requireRole(['Patient'])) return;

            const currentUser = getCurrentUser();
            $('#patientName').val(currentUser.fullName);
            $('#patientPhone').val(currentUser.phoneNumber);

            const now = new Date();
            const today = [
                now.getFullYear(),
                String(now.getMonth() + 1).padStart(2, '0'),
                String(now.getDate()).padStart(2, '0')
            ].join('-');
            $('#bookingDate').val(today);
            $('#bookingDate').attr('min', today);

            const initialDoctorId = @Model.SelectedDoctorId;
            if (initialDoctorId) {
                $('#selectDoctor').val(initialDoctorId);
            }

            loadDoctors(initialDoctorId);
            $('#selectDoctor, #bookingDate').change(loadSlots);

            $(document).on('click', '.slot-item-btn', function() {
                $('.slot-item-btn').removeClass('is-selected');
                $(this).addClass('is-selected');
                $('#selectedScheduleId').val($(this).data('schedule-id'));
                $('#btnSubmitBooking').prop('disabled', false);
            });

            $('#formBooking').submit(function(e) {
                e.preventDefault();

                const doctorId = parseInt($('#selectDoctor').val());
                const scheduleId = parseInt($('#selectedScheduleId').val());
                const patientName = $('#patientName').val().trim();
                const patientPhone = $('#patientPhone').val().trim();
                const reason = $('#reason').val().trim();

                if (!scheduleId || scheduleId <= 0) {
                    toastr.warning('Vui lòng chọn một khung giờ ca khám!');
                    return;
                }

                const bookingDto = {
                    doctorId: doctorId,
                    scheduleId: scheduleId,
                    patientName: patientName,
                    patientPhone: patientPhone,
                    reason: reason
                };

                $('#btnSubmitBooking').prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span> Đang xử lý đặt lịch...');

                $.ajax({
                    url: `${API_BASE_URL}/appointments`,
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(bookingDto),
                    headers: getAuthHeaders(),
                    success: function(res) {
                        toastr.success(res.message || 'Đặt lịch khám bệnh thành công!');
                        setTimeout(function() {
                            window.location.href = '/Patient/History';
                        }, 1500);
                    },
                    error: function(xhr) {
                        $('#btnSubmitBooking').prop('disabled', false).html('<i class="bi bi-send me-2"></i> Xác Nhận Đặt Lịch');

                        if (handleAuthError(xhr)) return;

                        if (xhr.status === 409) {
                            toastr.error(xhr.responseJSON?.message || 'Khung giờ này vừa có người đặt. Vui lòng chọn slot khác!');
                            loadSlots();
                        } else if (xhr.status === 400) {
                            const errors = xhr.responseJSON?.errors;
                            if (errors && errors.length > 0) {
                                errors.forEach(err => toastr.error(err.errorMessage));
                            } else {
                                toastr.error(xhr.responseJSON?.message || 'Thông tin nhập chưa hợp lệ.');
                            }
                        } else {
                            toastr.error('Đặt lịch thất bại. Vui lòng thử lại sau.');
                        }
                    }
                });
            });
        });

        function loadDoctors(selectedDoctorId) {
            const $select = $('#selectDoctor');
            $select.prop('disabled', true).empty().append(
                $('<option>', { value: '', text: 'Đang tải danh sách bác sĩ...' })
            );

            $.ajax({
                url: `${API_BASE_URL}/doctors/search`,
                type: 'GET',
                success: function(doctors) {
                    $select.empty();

                    if (!doctors || doctors.length === 0) {
                        $select.prop('disabled', true).append(
                            $('<option>', { value: '', text: 'Không có bác sĩ đang hoạt động' })
                        );
                        $('#slotsContainer').html('<div class="w-100 text-center py-3 text-muted">Hiện chưa có bác sĩ để đặt lịch.</div>');
                        return;
                    }

                    doctors.forEach(function(doctor) {
                        $select.append($('<option>', {
                            value: doctor.doctorId,
                            text: `${doctor.fullName} (${doctor.specializationName})`
                        }));
                    });

                    const hasSelectedDoctor = doctors.some(function(doctor) {
                        return doctor.doctorId === selectedDoctorId;
                    });
                    $select.val(String(hasSelectedDoctor ? selectedDoctorId : doctors[0].doctorId));
                    $select.prop('disabled', false);
                    loadSlots();
                },
                error: function() {
                    $select.empty().prop('disabled', true).append(
                        $('<option>', { value: '', text: 'Không thể tải danh sách bác sĩ' })
                    );
                    $('#slotsContainer').html(
                        '<div class="w-100 text-center py-3 text-danger">Không thể kết nối đến API. Vui lòng thử lại.</div>'
                    );
                }
            });
        }

        function loadSlots() {
            const doctorId = $('#selectDoctor').val();
            const date = $('#bookingDate').val();

            $('#selectedScheduleId').val(0);
            $('#btnSubmitBooking').prop('disabled', true);

            $('#slotsContainer').html(`
                <div class="w-100 text-center py-3 text-muted">
                    <span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span> Đang kiểm tra khung giờ rảnh...
                </div>
            `);

            $.ajax({
                url: `${API_BASE_URL}/schedules/available-slots?doctorId=${doctorId}&date=${date}`,
                type: 'GET',
                success: function(slots) {
                    renderSlots(slots);
                },
                error: function() {
                    $('#slotsContainer').html(
                        '<div class="w-100 text-center py-3 text-danger">Không thể tải khung giờ trống. Vui lòng thử lại.</div>'
                    );
                    return;
                }
            });
        }

        function renderSlots(slots) {
            if (!slots || slots.length === 0) {
                $('#slotsContainer').html(`
                    <div class="w-100 text-center py-3 text-danger fw-semibold">
                        <i class="bi bi-calendar-x me-2"></i>Không có khung giờ rảnh nào trong ngày này. Vui lòng chọn ngày khác.
                    </div>
                `);
                return;
            }

            let html = '';
            slots.forEach(s => {
                const timeText = `${s.startTime.substring(0,5)} - ${s.endTime.substring(0,5)}`;
                html += `
                    <button type="button" class="btn slot-btn slot-item-btn" data-schedule-id="${s.scheduleId}">
                        <i class="bi bi-clock me-1"></i> ${timeText}
                    </button>
                `;
            });
            $('#slotsContainer').html(html);
        }
    </script>
}
